# ------------------------------------------------------------
# Renewlet one-command Docker deployment
# ------------------------------------------------------------

# Public service port. The container always listens on 3000.
PORT="3000"

# Image source. Docker Hub is the default; switch to GHCR if Docker Hub is unavailable:
# RENEWLET_IMAGE="ghcr.io/zhiyingzzhou/renewlet:latest"
RENEWLET_IMAGE="zhiyingzzhou/renewlet:latest"

# Go runtime soft memory limit. 128MiB is enough for small VPS/NAS deployments.
GOMEMLIMIT="128MiB"
MEM_LIMIT="256m"

# Container time zone. Business reminder time still follows each user's in-app time zone.
TZ="Asia/Shanghai"

# Public app URL, used in notification and password-reset email links.
# For reverse proxy deployments, set this to your HTTPS domain later.
APP_URL="http://localhost:3000"

# Generated by deploy/docker-deploy.sh on first install.
# PB_ENCRYPTION_KEY must be exactly 32 characters; do not rotate it casually.
PB_ENCRYPTION_KEY=""
# CRON_SECRET is a Bearer token for external notification cron calls.
CRON_SECRET=""

# Optional: enable PocketBase password-reset email.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="smtp-user"
# SMTP_PASSWORD="smtp-password"
# SMTP_FROM="Renewlet <noreply@example.com>"
# SMTP_TLS="false"

# Optional: PocketBase automatic backups, for example daily 03:00 and keep 7 copies.
# BACKUPS_CRON="0 3 * * *"
# BACKUPS_CRON_MAX_KEEP="7"

# Built-in notification scheduler. Keep this enabled for normal Docker/VPS hosting.
NOTIFICATION_SCHEDULER_ENABLED="true"
NOTIFICATION_SCHEDULER_CRON="* * * * *"
NOTIFICATION_CRON_WINDOW_MINUTES="2"
NOTIFICATION_MAX_RETRIES="3"
NOTIFICATION_STALE_SENDING_MINUTES="15"

# Data is stored in ./data and mounted to /pb_data inside the container.
